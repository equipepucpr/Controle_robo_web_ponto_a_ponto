<?xml version="1.0"?>
<!--
  Robô diferencial para simulação no Gazebo Harmonic (Jazzy).

  Dimensões batem com o URDF real (wheel_base=0.45, wheel_radius=0.085)
  para que os tunings de slam_toolbox/Nav2 transfiram razoavelmente.

  Tópicos publicados pelos plugins:
    - /cmd_vel  (consumido pela DiffDrive)
    - /odom     (publicado pela DiffDrive a 30 Hz)
    - /tf       (odom → base_link via DiffDrive)
    - /scan     (LiDAR GPU, frame_id=base_laser, ~10 Hz)
-->
<sdf version="1.9">
  <model name="sim_robot">
    <pose>0 0 0.12 0 0 0</pose>

    <!-- ====== base_link (corpo principal) ====== -->
    <link name="base_link">
      <inertial>
        <mass>10.0</mass>
        <inertia>
          <ixx>0.2</ixx><iyy>0.2</iyy><izz>0.2</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="body_visual">
        <geometry><box><size>0.50 0.45 0.10</size></box></geometry>
        <material>
          <ambient>0.3 0.3 0.35 1</ambient>
          <diffuse>0.5 0.5 0.55 1</diffuse>
        </material>
      </visual>
      <collision name="body_collision">
        <geometry><box><size>0.50 0.45 0.10</size></box></geometry>
      </collision>
    </link>

    <!-- ====== Rodas ====== -->
    <link name="left_wheel">
      <pose>0 0.225 -0.05 -1.5707 0 0</pose>
      <inertial>
        <mass>1.5</mass>
        <inertia>
          <ixx>0.005</ixx><iyy>0.005</iyy><izz>0.009</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="left_wheel_visual">
        <geometry><cylinder><radius>0.085</radius><length>0.06</length></cylinder></geometry>
        <material><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
      <collision name="left_wheel_collision">
        <geometry><cylinder><radius>0.085</radius><length>0.06</length></cylinder></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
    </link>
    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
      </axis>
    </joint>

    <link name="right_wheel">
      <pose>0 -0.225 -0.05 1.5707 0 0</pose>
      <inertial>
        <mass>1.5</mass>
        <inertia>
          <ixx>0.005</ixx><iyy>0.005</iyy><izz>0.009</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="right_wheel_visual">
        <geometry><cylinder><radius>0.085</radius><length>0.06</length></cylinder></geometry>
        <material><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
      <collision name="right_wheel_collision">
        <geometry><cylinder><radius>0.085</radius><length>0.06</length></cylinder></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
    </link>
    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
      </axis>
    </joint>

    <!-- ====== Caster esférico traseiro (estabilidade) ====== -->
    <link name="caster">
      <pose>-0.20 0 -0.07 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="caster_visual">
        <geometry><sphere><radius>0.035</radius></sphere></geometry>
      </visual>
      <collision name="caster_collision">
        <geometry><sphere><radius>0.035</radius></sphere></geometry>
        <surface>
          <friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction>
        </surface>
      </collision>
    </link>
    <joint name="caster_joint" type="fixed">
      <parent>base_link</parent>
      <child>caster</child>
    </joint>

    <!-- ====== LiDAR ====== -->
    <link name="base_laser">
      <pose>0.10 0 0.17 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="lidar_visual">
        <geometry><cylinder><radius>0.038</radius><length>0.04</length></cylinder></geometry>
        <material><diffuse>0.0 0.3 0.8 1</diffuse></material>
      </visual>
      <sensor name="lidar" type="gpu_lidar">
        <update_rate>10</update_rate>
        <topic>scan</topic>
        <always_on>1</always_on>
        <visualize>true</visualize>
        <gz_frame_id>base_laser</gz_frame_id>
        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.10</min>
            <max>12.0</max>
            <resolution>0.01</resolution>
          </range>
        </lidar>
      </sensor>
    </link>
    <joint name="laser_joint" type="fixed">
      <parent>base_link</parent>
      <child>base_laser</child>
    </joint>

    <!-- ====== Plugins ====== -->
    <!-- Diferencial: consome /cmd_vel, publica /odom e TF odom->base_link -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.45</wheel_separation>
      <wheel_radius>0.085</wheel_radius>
      <odom_publish_frequency>30</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <tf_topic>/tf</tf_topic>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
    </plugin>

    <!-- Publica estados das juntas (rodas girando na visualização) -->
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>

    <!-- Publica pose de todos os links para os TFs estáticos secundários -->
    <plugin filename="gz-sim-pose-publisher-system"
            name="gz::sim::systems::PosePublisher">
      <publish_link_pose>true</publish_link_pose>
      <publish_sensor_pose>true</publish_sensor_pose>
      <publish_collision_pose>false</publish_collision_pose>
      <publish_visual_pose>false</publish_visual_pose>
      <publish_nested_model_pose>false</publish_nested_model_pose>
      <use_pose_vector_msg>true</use_pose_vector_msg>
      <static_publisher>true</static_publisher>
      <static_update_frequency>1</static_update_frequency>
    </plugin>
  </model>
</sdf>
