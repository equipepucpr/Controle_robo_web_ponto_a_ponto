<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="hoverboard_robot">

  <!-- ============================================================
       Hoverboard Robot Description
       Adjust dimensions to match your actual robot:
         wheel_radius: radius of the hoverboard wheels (meters)
         wheel_base:   distance between left and right wheel centers (meters)
         lidar_x:      lidar forward offset from robot center (meters)
         lidar_z:      lidar height above base_link (meters)
       ============================================================ -->

  <xacro:property name="wheel_radius" value="0.085"/>
  <xacro:property name="wheel_width"  value="0.06"/>
  <xacro:property name="wheel_base"   value="0.45"/>

  <xacro:property name="body_length"  value="0.50"/>
  <xacro:property name="body_width"   value="0.45"/>
  <xacro:property name="body_height"  value="0.10"/>

  <!-- LiDAR position: slightly forward and on top -->
  <xacro:property name="lidar_x"      value="0.10"/>
  <xacro:property name="lidar_z"      value="0.12"/>

  <!-- pi já existe no xacro como constante embutida -->

  <!-- ======= base_footprint (ground projection) ======= -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ======= base_link (center of robot body) ======= -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- ======= Left Wheel ======= -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 ${wheel_base/2} ${-body_height/2}" rpy="${-pi/2} 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.009"/>
    </inertial>
  </link>

  <!-- ======= Right Wheel ======= -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 ${-wheel_base/2} ${-body_height/2}" rpy="${pi/2} 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.009"/>
    </inertial>
  </link>

  <!-- ======= LiDAR (FHL-LD20) ======= -->
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_laser"/>
    <origin xyz="${lidar_x} 0 ${body_height/2 + lidar_z}" rpy="0 0 0"/>
  </joint>

  <link name="base_laser">
    <visual>
      <geometry>
        <cylinder radius="0.038" length="0.04"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.3 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.038" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

</robot>
