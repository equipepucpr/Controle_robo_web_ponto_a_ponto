<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="hoverboard_robot">

  <!-- ============================================================
       Hoverboard Robot Description
       Adjust dimensions to match your actual robot:
         wheel_radius: radius of the hoverboard wheels (meters)
         wheel_base:   distance between left and right wheel centers (meters)
         lidar_x:      lidar forward offset from robot center (meters)
         lidar_z:      lidar height above base_link (meters)
       ============================================================ -->

  <xacro:property name="wheel_radius" value="0.085"/>
  <xacro:property name="wheel_width"  value="0.06"/>
  <xacro:property name="wheel_base"   value="0.45"/>

  <xacro:property name="body_length"  value="0.50"/>
  <xacro:property name="body_width"   value="0.45"/>
  <xacro:property name="body_height"  value="0.10"/>

  <!-- Livox Mid-360 position: ajuste pra refletir onde o Mid-360 foi montado.
       lidar_x: offset pra frente a partir do centro do base_link (m).
       lidar_z: altura acima do topo do corpo (m). -->
  <xacro:property name="lidar_x"      value="0.10"/>
  <xacro:property name="lidar_z"      value="0.12"/>
  <!-- Mid-360: cilindro ~65 mm de diâmetro por ~60 mm de altura. -->
  <xacro:property name="livox_radius" value="0.033"/>
  <xacro:property name="livox_height" value="0.060"/>

  <!-- pi já existe no xacro como constante embutida -->

  <!-- base_link é raiz do URDF. O TF body->base_link é publicado pelo
       fast_lio.launch.py (static_transform_publisher), colocando o robô embaixo
       do Mid-360 que o FAST-LIO2 rastreia. -->

  <!-- ======= base_link (center of robot body) ======= -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- ======= Left Wheel ======= -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 ${wheel_base/2} ${-body_height/2}" rpy="${-pi/2} 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.009"/>
    </inertial>
  </link>

  <!-- ======= Right Wheel ======= -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 ${-wheel_base/2} ${-body_height/2}" rpy="${pi/2} 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.009"/>
    </inertial>
  </link>

  <!-- ======= LiDAR (Livox Mid-360) =======
       O frame livox_frame é o usado pelo livox_ros_driver2 nas mensagens
       /livox/lidar e /livox/imu. É um nó filho de base_link puramente pra
       visualização — o FAST-LIO2 usa seu próprio frame "body" (que fica
       conectado ao base_link via static TF definido no fast_lio.launch.py). -->
  <joint name="livox_joint" type="fixed">
    <parent link="base_link"/>
    <child link="livox_frame"/>
    <origin xyz="${lidar_x} 0 ${body_height/2 + lidar_z}" rpy="0 0 0"/>
  </joint>

  <link name="livox_frame">
    <visual>
      <geometry>
        <cylinder radius="${livox_radius}" length="${livox_height}"/>
      </geometry>
      <material name="black">
        <color rgba="0.05 0.05 0.05 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${livox_radius}" length="${livox_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.265"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

</robot>
